---
/* ── Contact info data ── */
const contactItems = [
  { icon: "📧", label: "Email", value: "contact@witsawa.com" },
  { icon: "💬", label: "LINE", value: "@witsawa (LINE Official)" },
  { icon: "📍", label: "Location", value: "Bangkok, Thailand" },
  { icon: "🏢", label: "Hub", value: "True Digital Park Partner" },
];

const socialLinks = [
  { href: "https://facebook.com/witsawa", icon: "📘", label: "Facebook" },
  { href: "https://page.line.me/witsawa", icon: "💚", label: "LINE" },
];

const serviceOptions = [
  "Mobile Application",
  "Web Application",
  "ERP System",
  "POS System",
  "Payment Gateway Integration",
  "LINE Integration",
  "CTO as a Service",
  "ESG & Digital Transformation",
  "Other",
];
---

<!-- ══════════════════════════ Contact Section ══════════════════════════ -->
<section id="contact" class="contact-section">
  <div style="max-width: 1100px; margin: 0 auto;">
    <!-- Header -->
    <div style="text-align: center; margin-bottom: 56px;" class="reveal">
      <div class="section-tag">Get In Touch</div>
      <h2 class="section-title">
        Let's Build Something <span class="accent">Together</span>
      </h2>
      <p class="section-desc" style="margin: 0 auto; max-width: 500px;">
        Ready to transform your idea into reality? Reach out and let's start the
        conversation.
      </p>
    </div>

    <!-- Content Grid: Info + Form -->
    <div class="contact-grid">
      <!-- Left: Contact Info -->
      <div class="contact-info reveal">
        {
          contactItems.map(({ icon, label, value }) => (
            <div class="contact-item">
              <div class="contact-item-icon">{icon}</div>
              <div>
                <div class="contact-item-label">{label}</div>
                <div class="contact-item-val">{value}</div>
              </div>
            </div>
          ))
        }

        <!-- Social Buttons -->
        <div
          style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px;"
        >
          {
            socialLinks.map(({ href, icon, label }) => (
              <a
                href={href}
                target="_blank"
                class="btn-ghost"
                style="font-size:13px; padding: 10px 18px;"
              >
                {icon} {label}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="glass-card reveal reveal-delay-2" style="padding: 36px;">
        <div class="contact-form">
          <!-- Name Row -->
          <div class="form-row">
            <div class="form-group">
              <label>First Name</label>
              <input type="text" placeholder="John" />
            </div>
            <div class="form-group">
              <label>Last Name</label>
              <input type="text" placeholder="Doe" />
            </div>
          </div>

          <!-- Email -->
          <div class="form-group">
            <label>Email</label>
            <input type="email" placeholder="john@company.com" />
          </div>

          <!-- Service Select -->
          <div class="form-group">
            <label>Service Interested In</label>
            <select>
              <option value="">Select a service...</option>
              {serviceOptions.map((service) => <option>{service}</option>)}
            </select>
          </div>

          <!-- Message -->
          <div class="form-group">
            <label>Tell us about your project</label>
            <textarea
              rows="4"
              placeholder="Describe your idea, requirements, or questions..."
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            id="submitBtn"
            class="btn-primary"
            style="width: 100%; justify-content: center;"
          >
            Send Message →
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════ Styles ══════════════════════════ -->
<style>
  /* ── Section Container ── */
  .contact-section {
    padding: 100px 5%;
  }

  /* ── 2-Column Grid ── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    max-width: 1100px;
    margin: 0 auto;
    align-items: start;
  }

  /* ── Contact Info Cards ── */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 16px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.11),
      rgba(255, 255, 255, 0.05)
    );
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 14px;
    padding: 18px 20px;
    backdrop-filter: blur(24px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .contact-item-icon {
    width: 42px;
    height: 42px;
    min-width: 42px;
    background: rgba(0, 102, 255, 0.1);
    border: 1px solid rgba(0, 102, 255, 0.2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .contact-item-label {
    font-size: 11px;
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
  }

  .contact-item-val {
    font-size: 14px;
    font-weight: 500;
    margin-top: 2px;
  }

  /* ── Form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .form-group label {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.5px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    outline: none;
    transition:
      border-color 0.2s,
      background 0.2s;
    resize: none;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(200, 215, 255, 0.25);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: rgba(56, 189, 248, 0.5);
    background: rgba(0, 102, 255, 0.06);
    box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.08);
  }

  .form-group select option {
    background: #0a0f1e;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
