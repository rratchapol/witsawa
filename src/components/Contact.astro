<section id="contact" class="contact-section">
  <div style="max-width: 1100px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 56px;" class="reveal">
      <div class="section-tag">Get In Touch</div>
      <h2 class="section-title">Let's Build Something <span class="accent">Together</span></h2>
      <p class="section-desc" style="margin: 0 auto; max-width: 500px;">Ready to transform your idea into reality? Reach out and let's start the conversation.</p>
    </div>
    <div class="contact-grid">
      <div class="contact-info reveal">
        <div class="contact-item">
          <div class="contact-item-icon">📧</div>
          <div><div class="contact-item-label">Email</div><div class="contact-item-val">contact@witsawa.com</div></div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon">💬</div>
          <div><div class="contact-item-label">LINE</div><div class="contact-item-val">@witsawa (LINE Official)</div></div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon">📍</div>
          <div><div class="contact-item-label">Location</div><div class="contact-item-val">Bangkok, Thailand</div></div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon">🏢</div>
          <div><div class="contact-item-label">Hub</div><div class="contact-item-val">True Digital Park Partner</div></div>
        </div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px;">
          <a href="https://facebook.com/witsawa" target="_blank" class="btn-ghost" style="font-size:13px; padding: 10px 18px;">📘 Facebook</a>
          <a href="https://page.line.me/witsawa" target="_blank" class="btn-ghost" style="font-size:13px; padding: 10px 18px;">💚 LINE</a>
        </div>
      </div>
      <div class="glass-card reveal reveal-delay-2" style="padding: 36px;">
        <div class="contact-form">
          <div class="form-row">
            <div class="form-group"><label>First Name</label><input type="text" placeholder="John" /></div>
            <div class="form-group"><label>Last Name</label><input type="text" placeholder="Doe" /></div>
          </div>
          <div class="form-group"><label>Email</label><input type="email" placeholder="john@company.com" /></div>
          <div class="form-group">
            <label>Service Interested In</label>
            <select>
              <option value="">Select a service...</option>
              <option>Mobile Application</option>
              <option>Web Application</option>
              <option>ERP System</option>
              <option>POS System</option>
              <option>Payment Gateway Integration</option>
              <option>LINE Integration</option>
              <option>CTO as a Service</option>
              <option>ESG & Digital Transformation</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group"><label>Tell us about your project</label><textarea rows="4" placeholder="Describe your idea, requirements, or questions..."></textarea></div>
          <button id="submitBtn" class="btn-primary" style="width: 100%; justify-content: center;">Send Message →</button>
        </div>
      </div>
    </div>
  </div>
</section>
