---
/* ── Tech stack items ── */
const techItems = [
  { icon: "⚛️", name: "React" },
  { icon: "🟩", name: "Node.js" },
  { icon: "🐘", name: "PostgreSQL" },
  { icon: "🍃", name: "MongoDB" },
  { icon: "☁️", name: "AWS Cloud" },
  { icon: "🐳", name: "Docker" },
  { icon: "📱", name: "React Native" },
  { icon: "🎯", name: "Flutter" },
  { icon: "🔷", name: "TypeScript" },
  { icon: "🐍", name: "Python" },
  { icon: "🌐", name: "Next.js" },
  { icon: "🔧", name: "DevOps / CI" },
];
---

<!-- ══════════════════════════ Tech Stack Section ══════════════════════════ -->
<section class="tech-section">
  <!-- Header -->
  <div class="tech-header reveal">
    <div class="section-tag">Technology</div>
    <h2 class="section-title">Our <span class="accent">Tech Stack</span></h2>
    <p class="section-desc" style="margin: 0 auto; max-width: 440px;">
      We work with modern, battle-tested technologies to build future-proof
      solutions.
    </p>
  </div>

  <!-- Tech Grid -->
  <div class="tech-grid reveal reveal-delay-1">
    {
      techItems.map(({ icon, name }) => (
        <div class="tech-item">
          <span class="icon">{icon}</span>
          <span class="name">{name}</span>
        </div>
      ))
    }
  </div>
</section>

<!-- ══════════════════════════ Styles ══════════════════════════ -->
<style>
  /* ── Section ── */
  .tech-section {
    padding: 80px 5%;
  }

  .tech-header {
    text-align: center;
    margin-bottom: 52px;
  }

  /* ── Grid ── */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    max-width: 900px;
    margin: 0 auto;
  }

  /* ── Tech Item ── */
  .tech-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.11),
      rgba(255, 255, 255, 0.05)
    );
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 14px;
    padding: 20px 12px;
    backdrop-filter: blur(22px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 4px 16px rgba(0, 0, 0, 0.38);
    transition:
      background 0.3s,
      border-color 0.3s,
      transform 0.3s;
    cursor: default;
  }

  .tech-item:hover {
    background: rgba(0, 102, 255, 0.1);
    border-color: rgba(56, 189, 248, 0.3);
    transform: translateY(-4px);
  }

  .tech-item .icon {
    font-size: 28px;
  }

  .tech-item .name {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.3px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .tech-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 768px) {
    .tech-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
