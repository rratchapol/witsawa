---
import logoWitsawa from '../assets/logoWitsawa.png';

interface Props {
  title?: string;
}
const { title = "Witsawa Corporation — Code Your Dream, Write the Future" } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={logoWitsawa.src} />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <div id="bg-img"></div>
    <div class="page-wrap">
      <slot />
    </div>
    <script src="/src/scripts/main.ts"></script>
  </body>
</html>
